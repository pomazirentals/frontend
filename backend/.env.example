# Database
DATABASE_URL=guests.db

# Auth
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Anthropic (AI Assistant)
ANTHROPIC_API_KEY=

# Twilio (SMS Verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# App
APP_SECRET_KEY=your-app-secret-here
DEBUG=false

# Railway / Production Setup
# Set DEFAULT_TENANT_DOMAIN to your Railway hostname (e.g. myapp.up.railway.app)
# This seeds a tenant row so branding resolves correctly.
DEFAULT_TENANT_DOMAIN=

# First-time admin account creation (Railway only).
# Set these, deploy once — admin user is created. Then REMOVE them from Railway env.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
